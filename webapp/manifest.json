{
  "sap.app": {
    "id": "travel",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "title": "SAP Travel",
    "description": "Application de démonstration SAP UI5 Travel"
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "sap-icon://world"
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "travel.view.App",
      "type": "XML",
      "async": true,
      "id": "appView"
    },
    "dependencies": {
      "minUI5Version": "1.96.0",
      "libs": {
        "sap.m": {}
      }
    },
    "models": {
      "": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/travel.json"
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "travel.i18n.i18n"
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "travel.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        {
          "pattern": "",
          "name": "app"
        },
        {
          "pattern": "detail/{travelId}",
          "name": "detail",
          "target": "detail"
        }
      ],
      "targets": {
        "detail": {
          "viewName": "Detail"
        }
      }
    }
  }
}
